[Unit]
Description=AI ChatOps Service
After=network.target ollama.service

[Service]
Type=simple
User={{ app_user | default('admin') }}
Group={{ app_user | default('admin') }}
WorkingDirectory=/opt/ai-chatops
ExecStart=/usr/bin/python3 /opt/ai-chatops/chatops.py
Restart=always
RestartSec=5
Environment=OLLAMA_HOST=localhost:{{ ollama_api_port | default(11434) }}
Environment=OLLAMA_MODEL={{ chatops_model | default('llama2') }}

[Install]
WantedBy=multi-user.target
