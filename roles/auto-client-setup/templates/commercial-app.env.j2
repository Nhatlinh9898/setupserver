# Environment Variables cho Commercial App
NODE_ENV={{ node_env | default('production') }}
PORT={{ commercial_app_port | default(3000) }}

# App URL
VITE_APP_URL={{ vite_app_url | default('http://localhost:3000') }}

# Database Connection
DATABASE_URL={{ database_url | default('postgresql://user:password@localhost:5432/commercialapp') }}

# Firebase Configuration (nếu dùng)
FIREBASE_API_KEY={{ firebase_api_key | default('') }}
FIREBASE_AUTH_DOMAIN={{ firebase_auth_domain | default('') }}
FIREBASE_PROJECT_ID={{ firebase_project_id | default('') }}
FIREBASE_STORAGE_BUCKET={{ firebase_storage_bucket | default('') }}
FIREBASE_MESSAGING_SENDER_ID={{ firebase_messaging_sender_id | default('') }}
FIREBASE_APP_ID={{ firebase_app_id | default('') }}

# P2P Relay (GunDB) Configuration
P2P_RELAY_ENABLED={{ p2p_relay_enabled | default('true') }}
P2P_RELAY_PORT={{ p2p_relay_port | default(8765) }}

# Mesh Network Configuration
MESH_NETWORK_ENABLED={{ mesh_network_enabled | default('true') }}
MESH_NETWORK_IP={{ mesh_network_ip | default('10.0.0.1') }}

# Socket.io Configuration
SOCKET_IO_ENABLED={{ socket_io_enabled | default('true') }}
SOCKET_IO_PORT={{ socket_io_port | default(3001) }}

# AI/ML Configuration
AI_MODELS_ENABLED={{ ai_models_enabled | default('false') }}
TRANSFORMERS_JS_ENABLED={{ transformers_js_enabled | default('false') }}

# Security
JWT_SECRET={{ jwt_secret | default('change-this-secret-in-production') }}
ENCRYPTION_KEY={{ encryption_key | default('change-this-encryption-key') }}

# Logging
LOG_LEVEL={{ log_level | default('info') }}
LOG_FILE={{ log_file | default('/var/log/commercial-app/app.log') }}
