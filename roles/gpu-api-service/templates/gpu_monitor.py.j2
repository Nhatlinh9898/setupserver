#!/usr/bin/env python3
"""
GPU Monitoring Script
Monitor GPU usage and log metrics
"""

import torch
import time
import json
import logging
from datetime import datetime

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler('/opt/gpu-api/logs/gpu-monitor.log'),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

def monitor_gpu(interval={{ gpu_monitor_interval | default(60) }}):
    """
    Monitor GPU usage at specified interval
    """
    if not torch.cuda.is_available():
        logger.warning("GPU not available for monitoring")
        return
    
    logger.info("Starting GPU monitoring...")
    
    while True:
        try:
            device = torch.cuda.current_device()
            props = torch.cuda.get_device_properties(device)
            
            memory_total = props.total_memory
            memory_used = torch.cuda.memory_allocated(device)
            memory_free = memory_total - memory_used
            memory_percent = (memory_used / memory_total) * 100
            
            utilization = torch.cuda.utilization(device)
            
            metrics = {
                "timestamp": datetime.now().isoformat(),
                "device": device,
                "device_name": props.name,
                "memory_total_mb": memory_total / (1024**2),
                "memory_used_mb": memory_used / (1024**2),
                "memory_free_mb": memory_free / (1024**2),
                "memory_percent": memory_percent,
                "utilization_percent": utilization,
                "temperature": torch.cuda.temperature(device) if hasattr(torch.cuda, 'temperature') else None
            }
            
            logger.info(f"GPU Metrics: {json.dumps(metrics, indent=2)}")
            
            # Alert if memory usage is high
            if memory_percent > {{ gpu_memory_alert_threshold | default(90) }}:
                logger.warning(f"High GPU memory usage: {memory_percent:.2f}%")
            
            time.sleep(interval)
            
        except Exception as e:
            logger.error(f"Monitoring error: {str(e)}")
            time.sleep(interval)

if __name__ == "__main__":
    monitor_gpu()
