[Unit]
Description=AI Monitoring Service
After=network.target ollama.service

[Service]
Type=simple
User={{ app_user | default('admin') }}
Group={{ app_user | default('admin') }}
WorkingDirectory=/opt/ai-monitoring
ExecStart=/usr/bin/python3 /opt/ai-monitoring/monitor.py
Restart=always
RestartSec=5
Environment=OLLAMA_HOST=localhost:{{ ollama_api_port | default(11434) }}
Environment=OLLAMA_MODEL={{ ai_monitoring_model | default('llama2') }}
Environment=CHECK_INTERVAL={{ ai_monitoring_interval | default('300') }}

[Install]
WantedBy=multi-user.target
