[Unit]
Description={{ app_name | default('Go Application') }}
After=network.target

[Service]
Type=simple
User={{ app_user }}
WorkingDirectory={{ project_path }}
ExecStart={{ project_path }}/{{ app_name | default('app') }}
Restart=always
RestartSec=5
Environment=PORT={{ app_port | default(8080) }}

[Install]
WantedBy=multi-user.target
