"""
Federated Learning Client - Trains local model and sends updates to server
"""

import flwr as fl
import numpy as np
import torch
import torch.nn as nn
import torch.optim as optim
import logging
import os
from datetime import datetime

logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler('/opt/federated-learning/logs/fl_client.log'),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

# Simple neural network model
class SimpleModel(nn.Module):
    def __init__(self, input_size=10, hidden_size=50, output_size=10):
        super(SimpleModel, self).__init__()
        self.fc1 = nn.Linear(input_size, hidden_size)
        self.relu = nn.ReLU()
        self.fc2 = nn.Linear(hidden_size, output_size)
    
    def forward(self, x):
        x = self.fc1(x)
        x = self.relu(x)
        x = self.fc2(x)
        return x

# Flower client
class FlowerClient(fl.client.NumPyClient):
    def __init__(self, model, client_id):
        self.model = model
        self.client_id = client_id
        self.optimizer = optim.Adam(self.model.parameters(), lr=0.001)
        self.criterion = nn.MSELoss()
    
    def get_parameters(self, config):
        """Get current model parameters"""
        return [val.cpu().numpy() for _, val in self.model.state_dict().items()]
    
    def set_parameters(self, parameters):
        """Set model parameters from server"""
        params_dict = zip(self.model.state_dict().keys(), parameters)
        state_dict = {k: torch.tensor(v) for k, v in params_dict}
        self.model.load_state_dict(state_dict)
    
    def fit(self, parameters, config):
        """Train local model"""
        # Set parameters from server
        self.set_parameters(parameters)
        
        # Local training (simplified - use your actual data)
        num_epochs = {{ federated_local_epochs | default(5) }}
        batch_size = {{ federated_batch_size | default(32) }}
        
        self.model.train()
        total_loss = 0.0
        
        for epoch in range(num_epochs):
            # Generate dummy data (replace with your actual data)
            inputs = torch.randn(batch_size, 10)
            targets = torch.randn(batch_size, 10)
            
            self.optimizer.zero_grad()
            outputs = self.model(inputs)
            loss = self.criterion(outputs, targets)
            loss.backward()
            self.optimizer.step()
            
            total_loss += loss.item()
        
        avg_loss = total_loss / num_epochs
        logger.info(f"Client {self.client_id} - Local training completed. Loss: {avg_loss:.4f}")
        
        # Return updated parameters
        return self.get_parameters(config={}), len(inputs), {"loss": avg_loss}
    
    def evaluate(self, parameters, config):
        """Evaluate local model"""
        self.set_parameters(parameters)
        
        # Evaluation (simplified)
        self.model.eval()
        with torch.no_grad():
            inputs = torch.randn(100, 10)
            targets = torch.randn(100, 10)
            outputs = self.model(inputs)
            loss = self.criterion(outputs, targets)
        
        logger.info(f"Client {self.client_id} - Evaluation completed. Loss: {loss.item():.4f}")
        
        return loss.item(), len(inputs), {"loss": loss.item()}

# Start client
def start_client():
    logger.info(f"Starting Federated Learning Client {{ federated_client_id | default(1) }}...")
    
    # Initialize model
    model = SimpleModel()
    
    # Create Flower client
    client = FlowerClient(model, client_id={{ federated_client_id | default(1) }})
    
    # Start client
    fl.client.start_client(
        server_address="{{ federated_server_address | default('localhost:8080') }}",
        client=client
    )

if __name__ == "__main__":
    start_client()
