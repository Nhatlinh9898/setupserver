[Unit]
Description=Federated Learning Server
After=network.target

[Service]
Type=simple
User=fl
Group=fl
WorkingDirectory=/opt/federated-learning/server
Environment="PATH=/opt/federated-learning/venv/bin"
ExecStart=/opt/federated-learning/venv/bin/python fl_server.py
Restart=always
RestartSec=10

# Security
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
